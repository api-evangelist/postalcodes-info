    "_postman_id": "e2b4e1bb-b8dd-4e82-97b6-5453f7353a3a",
    "name": "PostalCodes.info Postal Code Reference API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "PostalCodes.info exposes postal-code reference data for lookup, testing, education, geospatial examples and data-quality workflows. Coverage and granularity vary by country. This is not an official delivery-grade postal authority API; validate shipping, compliance and certified address decisions against the relevant national postal authority.\n\nContact Support:\n Name: Pablo Cirre, PostalCodes.info\n Email: social@genera.work",
